# SEC EDGAR requires a descriptive User-Agent. Use your real name + email.
SEC_USER_AGENT="Your Name your-email@example.com"

# Free FRED API key: https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=

# Optional: enables the natural-language query box in the dashboard.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# Optional: how far back to pull FRED observations.
OBSERVATION_START=2013-01-01
